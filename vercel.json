{
  "version": 2,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://YOUR-RENDER-SERVICE.onrender.com/api/$1"
    }
    ,
    {
      "handle": "filesystem"
    },
    {
      "src": "/",
      "dest": "/static/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
